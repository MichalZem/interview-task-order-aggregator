{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "RequestLimits": {
    "MaxRequestBodyBytes": 262144
  },

  "OrderStore": {
    //"Kind": "InMemory",
    "Kind": "Redis",
    "Redis": {
      "ConnectionString": "localhost:6379",
      "HashKey": "order-aggregator:pending",
      "InstanceId": ""
    }
  },

  "Aggregation": {
    "FlushIntervalSeconds": 20,
    "SendMaxAttempts": 1,
    "SendRetryDelayMilliseconds": 200
  },

  "DeadLetter": {
    "Directory": "C://TEMP//DeadLetter"
  },

  "Observability": {
    "Enabled": true,
    "ServiceName": "OrderAggregator.Api",
    "OtlpEndpoint": "http://localhost:4317"
  },

  "AggregatedOrderSender": {
    "Kind": "Console",
    "Console": {
      "FailureProbability": 0.5
    }
  },

  "DeadLetter": {
    "Directory": "DeadLetter"
  },

  "ProductCatalog": {
    "FilePath": "products.json"
  },

  "ApiKey": {
    "HeaderName": "X-Api-Key",
    "Keys": [
      {
        "Name": "default-client",
        "Key": "dev-key-please-rotate-in-production-0001"
      },
      {
        "Name": "secondary-client",
        "Key": "dev-key-please-rotate-in-production-0002"
      }
    ]
  }
}
