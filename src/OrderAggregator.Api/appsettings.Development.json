{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "OrderAggregator": "Debug"
        }
    },

    "DeadLetter": {
        "Directory": "C://TEMP//DeadLetter",
        "ReplayIntervalSeconds": 5
    },

    "Aggregation": {
        "FlushIntervalSeconds": 20
    },

    "AggregatedOrderSender": {
        "Console": {
            "FailureProbability": 0.5
        }
    }
}
